---
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const recent = posts.slice(0, 6);
---

<aside class="sidebar">
	<section class="widget">
		<h3 class="widget-title">Mailing List</h3>
		<p>Get a heads-up whenever a new post goes up. Subscribe here.</p>
		<form class="mailing-list" action="#" method="post">
			<input type="email" name="email" placeholder="you@example.com" aria-label="Email address" required />
			<button type="submit" aria-label="Subscribe">
				<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
					<rect x="3" y="5" width="18" height="14" rx="1"></rect>
					<polyline points="3,7 12,13 21,7"></polyline>
				</svg>
			</button>
		</form>
	</section>

	<section class="widget">
		<h3 class="widget-title">Search</h3>
		<form class="search" role="search" onsubmit="event.preventDefault()">
			<input type="text" name="q" placeholder="Search posts…" aria-label="Search" autocomplete="off" />
			<button type="submit" aria-label="Search">
				<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
					<circle cx="11" cy="11" r="7"></circle>
					<line x1="21" y1="21" x2="16.65" y2="16.65"></line>
				</svg>
			</button>
		</form>
		<ul class="search-results" aria-live="polite"></ul>
		<script is:inline>
			(() => {
				const form = document.querySelector('.widget .search');
				if (!form) return;
				const input = form.querySelector('input[name="q"]');
				const resultsEl = form.parentElement.querySelector('.search-results');
				let pagefindPromise = null;
				const loadPagefind = () => {
					if (!pagefindPromise) {
						pagefindPromise = import('/pagefind/pagefind.js').catch(() => null);
					}
					return pagefindPromise;
				};
				const render = (items) => {
					if (!items.length) {
						resultsEl.innerHTML = '<li class="search-empty">No results</li>';
						return;
					}
					resultsEl.innerHTML = items.map((i) => `
						<li><a href="${i.url}">${i.meta.title || i.url}</a></li>
					`).join('');
				};
				let timer;
				input.addEventListener('input', (e) => {
					clearTimeout(timer);
					const q = e.target.value.trim();
					if (!q) { resultsEl.innerHTML = ''; return; }
					timer = setTimeout(async () => {
						const pf = await loadPagefind();
						if (!pf) {
							resultsEl.innerHTML = '<li class="search-empty">search index not built yet</li>';
							return;
						}
						const search = await pf.search(q);
						const items = await Promise.all(search.results.slice(0, 5).map((r) => r.data()));
						render(items);
					}, 180);
				});
			})();
		</script>
	</section>

	<section class="widget">
		<h3 class="widget-title">Recent Posts</h3>
		<ul class="recent-list">
			{
				recent.map((post) => (
					<li>
						<a href={`/blog/${post.id}/`}>{post.data.title}</a>
					</li>
				))
			}
		</ul>
	</section>
</aside>

<style>
	.sidebar {
		font-family: var(--serif);
		font-size: 0.95rem;
	}
	.widget {
		margin-bottom: 2em;
		padding-bottom: 1.5em;
		border-bottom: 1px solid var(--rule);
	}
	.widget:last-child {
		border-bottom: none;
	}
	.widget-title {
		font-family: var(--serif);
		font-size: 1rem;
		font-weight: 700;
		letter-spacing: 0;
		color: #000;
		border-bottom: 2px solid var(--accent);
		padding-bottom: 0.3em;
		margin: 0 0 0.8em;
	}
	.widget p {
		margin: 0 0 0.6em;
		line-height: 1.5;
	}
	.recent-list {
		list-style: none;
		margin: 0;
		padding: 0;
	}
	.recent-list li {
		padding: 0.5em 0;
		border-bottom: 1px dotted var(--rule);
		line-height: 1.35;
	}
	.recent-list li:last-child { border-bottom: none; }
	.recent-list a {
		font-weight: 600;
		display: block;
	}
	.search,
	.mailing-list {
		display: flex;
		gap: 0;
	}
	.search input[type="text"],
	.mailing-list input[type="email"] {
		flex: 1;
		min-width: 0;
		padding: 0.4em 0.6em;
		font-family: var(--serif);
		font-size: 0.95rem;
		border: 1px solid var(--rule);
		border-right: none;
		background: #fff;
		outline: none;
	}
	.search button,
	.mailing-list button {
		padding: 0.4em 0.9em;
		background: #c4703a;
		color: #fff;
		border: 1px solid #c4703a;
		font-family: var(--sans);
		font-weight: 600;
		font-size: 0.85rem;
		letter-spacing: 0;
		cursor: pointer;
		outline: none;
	}
	.search button:hover,
	.mailing-list button:hover {
		background: #a35a2c;
	}
	.search:focus-within,
	.mailing-list:focus-within {
		outline: 2px solid #c4703a;
		outline-offset: 0;
	}
	.search-results {
		list-style: none;
		margin: 0.6em 0 0;
		padding: 0;
	}
	.search-results li {
		padding: 0.5em 0;
		border-bottom: 1px dotted var(--rule);
		line-height: 1.35;
	}
	.search-results li:last-child { border-bottom: none; }
	.search-results a {
		font-weight: 600;
		display: block;
	}
	.search-results p {
		margin: 0.2em 0 0;
		font-size: 0.85rem;
		color: var(--muted);
		line-height: 1.4;
	}
	.search-results :global(mark) {
		background: rgba(196, 112, 58, 0.25);
		color: inherit;
		padding: 0 1px;
	}
	.search-empty {
		font-size: 0.85rem;
		color: var(--muted);
		font-style: italic;
	}
</style>

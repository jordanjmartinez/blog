---
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const recent = posts.slice(0, 6);
---

<aside class="sidebar">
	<section class="widget">
		<h3 class="widget-title">Mailing List</h3>
		<p>Get a heads-up whenever a new post goes up. Subscribe here.</p>
		<form class="mailing-list" action="#" method="post">
			<input type="email" name="email" placeholder="you@example.com" aria-label="Email address" required />
			<button type="submit" aria-label="Subscribe">
				<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
					<rect x="3" y="5" width="18" height="14" rx="1"></rect>
					<polyline points="3,7 12,13 21,7"></polyline>
				</svg>
			</button>
		</form>
	</section>

	<section class="widget">
		<h3 class="widget-title">Search</h3>
		<form action="https://duckduckgo.com/" method="get" target="_blank" class="search">
			<input type="hidden" name="sites" value="" />
			<input type="text" name="q" placeholder="Search this site…" aria-label="Search" />
			<button type="submit" aria-label="Search">
				<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
					<circle cx="11" cy="11" r="7"></circle>
					<line x1="21" y1="21" x2="16.65" y2="16.65"></line>
				</svg>
			</button>
		</form>
	</section>

	<section class="widget">
		<h3 class="widget-title">Recent Posts</h3>
		<ul class="recent-list">
			{
				recent.map((post) => (
					<li>
						<a href={`/blog/${post.id}/`}>{post.data.title}</a>
					</li>
				))
			}
		</ul>
	</section>
</aside>

<style>
	.sidebar {
		font-family: var(--serif);
		font-size: 0.95rem;
	}
	.widget {
		margin-bottom: 2em;
		padding-bottom: 1.5em;
		border-bottom: 1px solid var(--rule);
	}
	.widget:last-child {
		border-bottom: none;
	}
	.widget-title {
		font-family: var(--serif);
		font-size: 1rem;
		font-weight: 700;
		letter-spacing: 0;
		color: #000;
		border-bottom: 2px solid var(--accent);
		padding-bottom: 0.3em;
		margin: 0 0 0.8em;
	}
	.widget p {
		margin: 0 0 0.6em;
		line-height: 1.5;
	}
	.recent-list {
		list-style: none;
		margin: 0;
		padding: 0;
	}
	.recent-list li {
		padding: 0.5em 0;
		border-bottom: 1px dotted var(--rule);
		line-height: 1.35;
	}
	.recent-list li:last-child { border-bottom: none; }
	.recent-list a {
		font-weight: 600;
		display: block;
	}
	.search,
	.mailing-list {
		display: flex;
		gap: 0;
	}
	.search input[type="text"],
	.mailing-list input[type="email"] {
		flex: 1;
		min-width: 0;
		padding: 0.4em 0.6em;
		font-family: var(--serif);
		font-size: 0.95rem;
		border: 1px solid var(--rule);
		border-right: none;
		background: #fff;
	}
	.search button,
	.mailing-list button {
		padding: 0.4em 0.9em;
		background: #c4703a;
		color: #fff;
		border: 1px solid #c4703a;
		font-family: var(--sans);
		font-weight: 600;
		font-size: 0.85rem;
		letter-spacing: 0;
		cursor: pointer;
	}
	.search button:hover,
	.mailing-list button:hover {
		background: #a35a2c;
	}
</style>

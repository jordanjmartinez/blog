---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
import HeaderBg from '../assets/pexels-tima-miroshnichenko-5380837.jpg';
---

<header class="masthead">
	<div class="masthead-inner">
		<img class="masthead-bg" src={HeaderBg.src} alt="" aria-hidden="true" />
		<a href="/" class="brand">
			<span class="brand-text">
				<span class="brand-title">{SITE_TITLE}</span>
				<span class="brand-tagline"><span class="brand-tagline-prefix">~/</span> security <span class="brand-tagline-sep">/</span> news <span class="brand-tagline-sep">/</span> blog</span>
			</span>
		</a>
	</div>
</header>
<nav class="topnav">
	<div class="topnav-inner">
		<HeaderLink href="/">home</HeaderLink>
		<HeaderLink href="/about">about</HeaderLink>
	</div>
</nav>

<style>
	.masthead {
		color: #fff;
	}
	.masthead-inner {
		position: relative;
		width: 1100px;
		max-width: calc(100% - 2em);
		margin: 0 auto;
		padding: 1.4em 1em;
		background: var(--accent);
		border-bottom: 4px solid #c4703a;
		overflow: hidden;
	}
	.masthead-bg {
		position: absolute;
		top: 0;
		right: 0;
		bottom: 0;
		width: 35%;
		height: 100%;
		object-fit: cover;
		object-position: center 35%;
		opacity: 0.18;
		-webkit-mask-image: linear-gradient(to right, transparent 0%, rgba(0,0,0,0.4) 50%, black 100%);
		mask-image: linear-gradient(to right, transparent 0%, rgba(0,0,0,0.4) 50%, black 100%);
		pointer-events: none;
		user-select: none;
	}
	.brand {
		position: relative;
		z-index: 1;
		display: inline-flex;
		align-items: center;
		gap: 0.8em;
		color: #fff;
		text-decoration: none;
	}
	.brand:hover { text-decoration: none; color: #fff; }
	.brand-text {
		display: flex;
		flex-direction: column;
		line-height: 1.1;
	}
	.brand-title {
		font-family: 'JetBrains Mono', 'SFMono-Regular', Consolas, 'Liberation Mono', Menlo, monospace;
		font-size: 2.4rem;
		font-weight: 600;
		letter-spacing: 0;
	}
	.brand-tagline {
		font-family: 'JetBrains Mono', 'SFMono-Regular', Consolas, 'Liberation Mono', Menlo, monospace;
		font-size: 1rem;
		font-weight: 400;
		color: #aaa;
		margin-top: 0.4em;
		letter-spacing: 0.02em;
	}
	.brand-tagline-prefix {
		font-family: 'JetBrains Mono', 'SFMono-Regular', Consolas, 'Liberation Mono', Menlo, monospace;
		font-style: normal;
		color: #c4703a;
		margin-right: 0;
	}
	.brand-tagline-sep {
		color: #c4703a;
	}
	.topnav-inner {
		width: 1100px;
		max-width: calc(100% - 2em);
		margin: 0 auto;
		padding: 0 1em;
		display: flex;
		flex-wrap: wrap;
		gap: 0;
		background: #232323;
		border-bottom: 1px solid #111;
	}
	.topnav-inner :global(a) {
		display: inline-block;
		padding: 0.7em 1em;
		color: #ddd;
		font-family: 'JetBrains Mono', 'SFMono-Regular', Consolas, 'Liberation Mono', Menlo, monospace;
		font-size: 0.9rem;
		font-weight: 500;
		letter-spacing: 0;
		text-decoration: none;
	}
	.topnav-inner :global(a:hover) {
		color: #f5f5f5;
		text-decoration: none;
	}
	.topnav-inner :global(a.active) {
		color: #fff;
		text-decoration: none;
	}
	@media (max-width: 720px) {
		.brand-title { font-size: 1.8rem; }
		.brand-tagline { font-size: 0.85rem; }
		.masthead-bg { width: 55%; opacity: 0.35; }
		.topnav-inner :global(a) { padding: 0.6em 0.7em; font-size: 0.75rem; }
	}
</style>
